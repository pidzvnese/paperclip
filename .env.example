# Paperclip environment template.
# Copy to .env and set values. Do not commit .env.
#
# For Docker Compose: set at least POSTGRES_PASSWORD and BETTER_AUTH_SECRET.
# For local dev: DATABASE_URL can point to local Postgres or leave unset for embedded PGlite.

# --- Database (Docker Compose) ---
POSTGRES_USER=paperclip
POSTGRES_PASSWORD=change-me-min-16-chars
POSTGRES_DB=paperclip

# --- Database URL (server) ---
# Local dev: postgres://user:pass@localhost:5432/paperclip or leave unset for PGlite
# Docker: overridden by compose to postgres://user:pass@db:5432/paperclip
DATABASE_URL=postgres://paperclip:change-me-min-16-chars@localhost:5432/paperclip

# --- Server ---
PORT=3100
SERVE_UI=true

# --- Auth (required when PAPERCLIP_DEPLOYMENT_MODE=authenticated) ---
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=

# --- Agent JWT (heartbeats / local adapters). Optional: defaults to BETTER_AUTH_SECRET ---
# Generate: openssl rand -base64 32
PAPERCLIP_AGENT_JWT_SECRET=

# --- Deployment ---
PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_DEPLOYMENT_EXPOSURE=private
PAPERCLIP_PUBLIC_URL=http://localhost:3100

# --- Secrets (optional; defaults to local_encrypted under PAPERCLIP_HOME) ---
# PAPERCLIP_SECRETS_PROVIDER=local_encrypted
# PAPERCLIP_SECRETS_MASTER_KEY=   # 32-byte base64/hex, or set PAPERCLIP_SECRETS_MASTER_KEY_FILE

# --- Agent adapters: set so Claude/Codex/OpenCode heartbeats work in Docker ---
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# OPENCODE_API_KEY=
